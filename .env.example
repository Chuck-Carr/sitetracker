# =============================================================================
# SiteStratus — Environment Variables
# Copy this file to .env and fill in every value before deploying.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────

# Public URL of the app — must start with https:// in production.
# The Secure flag on session cookies is derived from this value.
NEXT_PUBLIC_APP_URL=https://sitestratus.com

# Secret key used to sign session JWTs.  Generate with:
#   openssl rand -base64 48
SESSION_SECRET=replace_with_a_long_random_secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Credentials for the Postgres container.
# Avoid special shell characters ($, !, #, @) in the password — they cause
# problems when the value is used inside a connection URL.
POSTGRES_USER=sitestratus
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=sitestratus

# Connection URL used by the app container (internal Docker service name).
# Keep the host as "postgres" — that is the Docker service name, not localhost.
DATABASE_URL=postgresql://sitestratus:replace_with_strong_password@postgres:5432/sitestratus

# ── MinIO (object storage) ────────────────────────────────────────────────────

# MinIO root credentials.  These become the S3 access key/secret for the app.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password

# S3 client settings — S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY must match
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD above.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=replace_with_strong_minio_password
S3_BUCKET=sitestratus
S3_FORCE_PATH_STYLE=true

# ── Caddy (HTTPS / reverse proxy) ────────────────────────────────────────────

# Your public domain name (no https://, no trailing slash).
DOMAIN=sitestratus.com

# Email address for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@sitestratus.com
